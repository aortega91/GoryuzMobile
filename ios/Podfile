def node_require(script)
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, min_ios_version_supported
prepare_react_native_project!

setup_permissions([
  'Camera',
  'PhotoLibrary',
])

linkage = :static
$RNFirebaseAsStaticFramework = true
Pod::UI.puts "Configuring Pod with statically linked Frameworks".green
use_frameworks! :linkage => linkage


target 'GoryuzMobile' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end

    # RNFBCrashlyticsModule.h imports <React/RCTBridgeModule.h> via a non-modular
    # header search path. When RNFBApp (compiled first as a static framework) textually
    # includes that same header, Clang claims RCTBridgeModule as belonging to
    # RNFBApp.RNFBAppModule. Subsequent compilation of RNFBCrashlytics then fails.
    # Fix: import through the RNFBApp framework module directly, which already exposes
    # RCTBridgeModule via its umbrella, so the symbol is accessed through the proper module.
    crashlytics_header = "#{Pod::Config.instance.installation_root}/../node_modules/@react-native-firebase/crashlytics/ios/RNFBCrashlytics/RNFBCrashlyticsModule.h"
    if File.exist?(crashlytics_header)
      content = File.read(crashlytics_header)
      patched = content.gsub(
        "#import <React/RCTBridgeModule.h>",
        "#import <RNFBApp/RNFBAppModule.h>"
      )
      if patched != content
        File.write(crashlytics_header, patched)
        Pod::UI.puts "Patched RNFBCrashlyticsModule.h: replaced <React/RCTBridgeModule.h> with <RNFBApp/RNFBAppModule.h>".green
      end
    end

  end
end
